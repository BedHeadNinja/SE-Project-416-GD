{% extends "inventory.html" %}

{% block productField %}
    {{ form.product_name.label }}<br>
    {{ form.product_name(size=32) }}
    {% for error in form.product_name.errors %}
        <span style="color: red;">[{{ error }}]</span>
    {% endfor %}
    {{ form.on_hand_count.label }}<br>
    {{ form.on_hand_count(size=32) }}
    {% for error in form.on_hand_count.errors %}
        <span style="color: red;">[{{ error }}]</span>    
    {% endfor %}
{% endblock%}
